# Serveur backend port
PORT=3000

# Clé secrète pour générer les tokens JWT (Authentification)
JWT_SECRET=smook_super_secret_key_123

# Lien de connexion PostgreSQL (à récupérer sur Neon ou Supabase)
DATABASE_URL=postgres://user:password@serveur.neon.tech/neondb?sslmode=require

# Lien d'API Cloudinary (à récupérer sur le dashboard Cloudinary, menu API Keys)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
